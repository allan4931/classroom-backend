# ── NetClass Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your actual values

# ── Server Configuration ───────────────────────────────────────────────────
NODE_ENV=production
PORT=8000

# ── Frontend URL ───────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com

# ── Database Configuration ───────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# ── JWT Configuration ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long

# ── Email Configuration (SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── Arcjet Security Configuration ───────────────────────────────────────────
ARCJET_KEY=your-arcjet-api-key

# ── Admin Configuration (Optional - use database seeding instead) ───────────────
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your-secure-admin-password

# ── Rate Limiting Configuration ───────────────────────────────────────────────
# Production: 100 requests per 15 minutes globally
# Production: 10 requests per 15 minutes for auth endpoints
# Development: 1000 requests per 15 minutes globally
# Development: 50 requests per 15 minutes for auth endpoints
